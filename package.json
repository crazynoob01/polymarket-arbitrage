{
  "name": "polymarket-arbitrage",
  "version": "1.0.0",
  "description": "TypeScript bot for researching and paper-trading weather prediction-market edges on Polymarket.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run tests/integration",
    "test:all": "npm run test && npm run test:integration",
    "test:watch": "vitest"
  },
  "keywords": [
    "polymarket",
    "prediction-markets",
    "weather",
    "arbitrage",
    "typescript",
    "trading-bot"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "vitest": "^4.1.0"
  }
}
