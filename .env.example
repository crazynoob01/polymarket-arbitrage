# Copy this file to .env and fill in only the services you use.
# Default PHASE=2a is paper trading and does not place live orders.

# Polymarket (required only for live trading: PHASE=2b or PHASE=2c)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_OFFICIAL_CLI=polymarket

# Telegram (optional; bot runs without notifications if blank)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# MySQL
MYSQL_ROOT_PASSWORD=change-this-local-root-password
MYSQL_HOST=mysql
MYSQL_DATABASE=polymarket_arb
MYSQL_USER=bot
MYSQL_PASSWORD=change-this-local-bot-password

# Bot config
PHASE=2a
CAPITAL=200
MAX_BET=20
MIN_BET=3
ESTIMATED_FEES=0

# Scan interval (minutes, default 15)
SCAN_INTERVAL_MINUTES=15

# Open-Meteo ensemble model IDs, comma-separated.
ENSEMBLE_MODELS=gfs_seamless,ecmwf_ifs025

# Log directory
LOG_DIR=logs
